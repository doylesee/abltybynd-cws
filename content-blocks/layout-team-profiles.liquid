{% capture page_sections_content %}{{ page_section_object.content }}{% endcapture %}

{% capture page_content_formatted %}{{ page_sections_content | replace: '<div class="item">','---<div class="item">' | replace: '</div>','</div>---' }}{% endcapture %}
{% assign page_content_array = page_content_formatted | split: '---' | assign_to: 'page_elements' %}

{% capture column_contents %}{% endcapture %}

{{ 0 | assign_to: 'item_index' }}
{% for page_element in page_elements %}
	{% if page_element contains '<div class="item">' %}
		{% capture add_spacer %}true{% endcapture %}
		{% capture column_contents %}
		{{ column_contents }}
		<div class="columns medium-6 large-3 end">
			<div class="team-profile space-small text-center same-height-item-js">
				<div class="team-profile__image space-xsmall">
					<img src="{{ page_sections[0].images[item_index].url }}" alt="" class="full-width" />
				</div>
				{{ page_element }}
			</div>
		</div>
		{% endcapture %}
		{{ item_index | plus: 1 | assign_to: 'item_index' }}

	{% elsif page_element != '' %}
		{% capture column_contents %}
		{{ column_contents }}
		<div class="column">
			{% if add_spacer == 'true' %}<div class="space-xlarge"></div>{% endif %}
			{% capture add_spacer %}false{% endcapture %}
			{{ page_element }}
			<div class="space-large"></div>
		</div>
		{% endcapture %}

	{% endif %}
{% endfor %}

<div class="space-small"></div>
<div class="row row--wide same-height-parent-js">
	{{ column_contents }}
</div>