{% comment %}
DO NOT EDIT THIS!
UPDATE THE CORRESPONDING THEME INSTEAD!
THEME CAN BE FOUND AT Career Sites > Theme Manager > Ability Beyond Theme

ONCE THEME HAS BEEN UPDATE, RE-APPLY IT TO ALL APPLICABLE SITES
{% endcomment %}

{% page_required_header %}

{% include '/_config__variables' %}

{% if cb_is_referral_site == 'true' and job.cfdisplay_PostingType != 'Internal' %}
    {% capture show_referral_content %}true{% endcapture %}
{% endif %}

{% unless root_url contains 'ttcportals.com' or cb_site_type == 'internal' or root_url contains 'agency' %}
{% if job.active? %}
    <script type="application/ld+json">
        {
            "@context" : "http://schema.org/",
            "@type" : "JobPosting",
            "title" : "{{ job.title | escape_javascript }}",
            "description" : "{{ job.description | escape_javascript | replace: "\'","'" | replace: "\$","$" }}",
            "identifier": {
                "@type": "PropertyValue",
                "name": "Ability Beyond",
                "value": "{{ job.external_id }}"
            },
            "datePosted" : "{{ job.updated_at | date: "%Y-%m-%d" }}",
            "hiringOrganization" : {
                "@type" : "Organization",
                "name" : "Ability Beyond",
                "logo" : "{{ root_url }}system/production/assets/372225/original/ability-beyond__icon-google.png"
            },
            "jobLocation" : {
                "@type" : "Place",
                "address" : {
                    "@type" : "PostalAddress",
                    "streetAddress" : "{{ job.location.street | escape_javascript }}",
                    "addressLocality" : "{{ job.location.city | escape_javascript }}",
                    "addressRegion" : "{{ job.location.state_prov | escape_javascript }}",
                    "postalCode" : "{{ job.location.postal_code | escape_javascript }}",
                    "addressCountry": "{{ job.location.country | escape_javascript }}"
                }
            }
        }
    </script>
{% endif %}
{% endunless %}

<div id="header-wrapper-fixed-bottom"></div>

<div id="job-details">
    <div class="job-details-preloader-js preloader preloader--job">
        <div class="facet-job-loading hide-for-print" role="alert" aria-labelledby="facet-job-loading">
            <div class="show-for-sr"><label id="facet-jobs-loading">Loading job</label></div>
        </div>
    </div>

    <div class="job-details-inner-js">
        <div class="job-details__heading padded-v-small background-3">
            <div class="row">
                <div class="columns large-5 small-text-center large-text-left padded-v-small job-details__heading-back">
                    <a href="/search/jobs" class="js" id="back-to-search">Back to Search Results</a>
                </div>
                <div class="columns large-7 small-text-center padded-v-small large-text-right job-details__prev-next-opportunity">
                    <a href="#" class="hide" id="job-details__prev-link">Previous Opportunity</a>
                    <a href="#" class="hide" id="job-details__next-link">Next Opportunity</a>
                </div><!--close .job-details__prev-next-opportunity-->
            </div>
        </div>

        <div class="padded-v-xlarge">
            <div class="row">
                <div class="columns similar-jobs-element-js medium-8--has-similar-jobs-js large-9--has-similar-jobs-js job-details__main">
                    <section>
                        <div class="row">
                            <div class="columns">
                                <h1>{{ job.title | html_safe }}</h1>
                            </div>
                            <div class="columns similar-jobs-element-js large-6--has-similar-jobs-js medium-6--no-similar-jobs-js">
                                {% unless job.active? %}
                                    <p>This job posting is no longer active.</p>
                                {% endunless %}
                                {% if notice %}
                                    <p>{{ notice }}</p>
                                {% endif %}
                                <p>
                                    {% capture job_location_state_prov_short_no_digit %}{{ job.location.state_prov_short | replace_global_regex: "[\d]", ":::" }}{% endcapture %}
                                    {% if job_location_state_prov_short_no_digit contains ':::' %}
                                        {% capture job_state_prov %}{{ job.location.state_prov }}{% endcapture %}
                                    {% else %}
                                        {% capture job_state_prov %}{{ job.location.state_prov_short }}{% endcapture %}
                                    {% endif %}
                                    Location: {{ job.location.city }}{% if job_state_prov != empty %}, {{ job_state_prov }}{% endif %}{% if job.location.country != empty %}, {{ job.location.country }}{% endif %}<br />
                                    <!-- Date Posted: <time datetime="{{ job.updated_at | date: '%Y-%m-%d' }}">{{ job.updated_at | date: '%b %-d, %Y' }}</time> -->

                                    {% if cb_site_type == 'external' %}
                                        {% if job.cfm5 != blank %}Schedule: {{ job.cfm5 }}{% endif %}
                                    {% elsif cb_site_type == 'internal' %}
                                        {% if job.cfm2 != blank %}Program Location: {{ job.cfm2 }}<br />{% endif %}
                                        {% if job.cfm3 != blank %}Program Type: {{ job.cfm3 }}<br />{% endif %}
                                        {% if job.cfdisplay_Supervisor != blank %}Supervisor: {{ job.cfdisplay_Supervisor }}<br />{% endif %}
                                        {% if job.cfm4 != blank %}Shift: {{ job.cfm4 }}<br />{% endif %}
                                        {% if job.cfm5 != blank %}Schedule: {{ job.cfm5 }}<br />{% endif %}
                                        {% if job.cfdisplay_Recruiter != blank %}Recruiter: {{ job.cfdisplay_Recruiter }}<br />{% endif %}
                                    {% endif %}
                                </p>
                                <div class="padded-v-medium--- space-small">
                                    <div class="cs_share_container cs_cfix clearfix">
                                        <span class="cs_share_text">Share:</span>
                                        <span class="cs_share_email--manual">
                                            <a class="cs_email_btn" href="mailto:?body={{ job.title | html_safe | replace: '&amp;','%26' }}%20in%20{{ job.location.city }},%20{{ job.location.state_prov }}:%20{{ root_url }}{{ job.url }}"><span class="show-for-sr">share to e-mail</span></a>
                                        </span>
                                        <span class="cs_share_twitter"></span>
                                        <span class="cs_share_facebook"></span>
                                        <span class="cs_share_linkedin"></span>
                                    </div>
                                </div>
                                {% if show_referral_content == 'true' %}
                                    <div class="social-share-url branded-search padded-xsmall space-small">
                                        <input type="text" width="50" value="{{ job.default_career_site_referral_url }}" id="social-share-url__input-1-js">
                                        <a href="javascript:void(0);" class="social-share-url__copy-js">Copy</a>
                                        {% comment %}Copy to clipboard only works if the input is visible! If it needs to be hidden, position the input off-screen{% endcomment %}
                                    </div>

                                    <div class="space-medium">
                                        {% if job.referral_incentive_amount != blank or job.referral_incentive_description != blank %}
                                            <h2 class="heading-6 space-none">Referral Reward</h2>
                                            <h3>
                                                {% if job.referral_incentive_amount != blank %}
                                                    {% if job.referral_incentive_currency == 'USD' or job.referral_incentive_currency == 'CAD' %}${% elsif job.referral_incentive_currency == 'EUR' %}€{% elsif job.referral_incentive_currency == 'GBP' %}£{% endif %}{{ job.referral_incentive_amount }} ({{ job.referral_incentive_currency }})
                                                {% endif %}
                                                {% if job.referral_incentive_description != blank %}{{ job.referral_incentive_description }}{% endif %}
                                            </h3>
                                        {% endif %}
                                    </div>
                                {% endif %}
                            </div>
                            <div class="columns similar-jobs-element-js large-6--has-similar-jobs-js large-text-right--has-similar-jobs-js medium-6--no-similar-jobs-js medium-text-right--no-similar-jobs-js">
                                <div class="space-small">
                                    <span id="apply-top" class="branded-button-1-outer">
                                        {% if job.active? %}
                                            {% if agency %}
                                                {{ job | link_to_apply:"Submit Candidate", agency }}
                                            {% else %}
                                                {{ job | link_to_apply:"Apply Now" }}
                                            {% endif %}
                                        {% endif %}
                                    </span>
                                </div>
                                <div class="space-medium">
                                    <a href="javascript:savejob('{{ job.external_id }}');" class="branded-button-1 hide save-job">Save Job</a>
                                    <a href="javascript:savejob('{{ job.external_id }}');" class="branded-button-2 hide job-saved">Saved</a>
                                    <script>
                                        // Save Jobs functionality
                                        var is_job_saved = false;
                                        var job_index;
                                        var job_saved_message;
                                        var c_jobs_temp = localStorage.getItem('c_jobs') ? JSON.parse(localStorage.getItem('c_jobs')) : [];
                                        var saved_jobs_query;

                                        // Detecting if job has been saved
                                        if (c_jobs_temp.indexOf('{{ job.external_id }}') >= 0) {
                                            $('.job-saved').removeClass('hide');
                                            is_job_saved = true;
                                            job_index = c_jobs_temp.indexOf('{{ job.external_id }}');
                                            $('.saved-jobs-alert__check').toggleClass('removed');
                                        }
                                        else {
                                            is_job_saved = false;
                                            $('.save-job').removeClass('hide');
                                        }

                                        function savejob(jobid) {
                                            {% if params['savejob'] == blank %}
                                                {% capture job_url_save %}{{ job.url }}{% if request_fullpath contains '?' %}&{% else %}?{% endif %}savejob=1{% endcapture %}
                                                window.location.replace('{{ job_url_save }}'); 
                                            {% endif %}
                                        }
                                        {% if params['savejob'] == '1' %}
                                            var job_item;
                                            if (is_job_saved == true) {
                                                is_job_saved = false;
                                                c_jobs_temp.splice(job_index,1);
                                                $('.saved-jobs-alert__check').toggleClass('removed');
                                                $('.saved-jobs-alert__message').html('Job has been removed.');
                                            }
                                            else {
                                                is_job_saved = true;
                                                c_jobs_temp.push('{{ job.external_id }}');
                                                $('.saved-jobs-alert__check').toggleClass('removed');
                                                $('.saved-jobs-alert__message').html('Job has been saved!');
                                            }

                                            localStorage.setItem('c_jobs', JSON.stringify(c_jobs_temp));
                                            
                                            $('.saved-jobs-alert-wrapper').fadeIn();
                                            setTimeout(function() {
                                                $('.button-saved').html('Saved');
                                                $('.saved-jobs-alert-wrapper').fadeOut();

                                                {% if request_fullpath contains '?savejob=1' %}
                                                    {% capture savejob_params %}?savejob=1{% endcapture %}
                                                {% else %}
                                                    {% capture savejob_params %}&savejob=1{% endcapture %}
                                                {% endif %}
                                                {% capture job_url_saved %}{{ request_fullpath | remove: savejob_params }}{% endcapture %}
                                                //location.reload();
                                                window.location.replace('{{ job_url_saved }}');
                                            }, 2000);
                                        {% endif %}
                                    </script>
                                </div>

                                {% if show_referral_content == 'true' %}
                                    <div id="refer-top" class="branded-button-1-outer space-small">
                                        {{ job | link_to_referral:'Refer a Friend' }}
                                    </div>
                                {% endif %}
                            </div>
                        </div>

                        <div class="padded-v-medium space-medium">
                            {{ job.description }}
                        </div>

                        <div class="row">
                            <div class="columns similar-jobs-element-js large-6--has-similar-jobs-js medium-6--no-similar-jobs-js">
                                <div class="padded-v-medium---">
                                    <div class="cs_share_container cs_cfix clearfix space-small">
                                        <span class="cs_share_text">Share:</span>
                                        <span class="cs_share_email--manual">
                                            <a class="cs_email_btn" href="mailto:?body={{ job.title | html_safe | replace: '&amp;','%26' }}%20in%20{{ job.location.city }},%20{{ job.location.state_prov }}:%20{{ root_url }}{{ job.url }}"><span class="hide">mail</span></a>
                                        </span>
                                        <span class="cs_share_twitter"></span>
                                        <span class="cs_share_facebook"></span>
                                        <span class="cs_share_linkedin"></span>
                                        {% if show_referral_content == 'true' %}
                                            <script type="text/javascript">CareerSite.Share.init({url: "{{job.default_career_site_referral_url}}"})</script>
                                        {% else %}
                                            <script type="text/javascript">talemetry.share();</script>
                                        {% endif %}
                                    </div>
                                    {% if show_referral_content == 'true' %}
                                        <div class="social-share-url branded-search padded-xsmall space-small">
                                            <input type="text" width="50" value="{{ job.default_career_site_referral_url }}" id="social-share-url__input-2-js">
                                            <a href="javascript:void(0);" class="social-share-url__copy-js">Copy</a>
                                            {% comment %}Copy to clipboard only works if the input is visible! If it needs to be hidden, position the input off-screen{% endcomment %}
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                            <div class="columns similar-jobs-element-js large-6--has-similar-jobs-js large-text-right--has-similar-jobs-js medium-6--no-similar-jobs-js medium-text-right--no-similar-jobs-js">
                                {% if job.active? %}
                                    {% if agency %}
                                        <a href="javascript:void(0);" id="apply-bottom" class="branded-button-1 space-large">Submit Candidate</a>
                                    {% else %}
                                        <a href="javascript:void(0);" id="apply-bottom" class="branded-button-1 space-large">Apply Now</a>
                                    {% endif %}
                                {% endif %}&nbsp;
                            </div>
                        </div>
                    </section>
                </div><!--close .job-details__main-->

                <div class="similar-jobs-element-js hide columns medium-4 large-3 job-details__sidebar">
                    <aside>
                        <div class="job-details__similar-jobs page-section">
                            <h2>Similar Jobs</h2>
                            <div class="similar-jobs--job-js"></div>
                            {% capture similar_jobs_query %}q={{ job.title | html_safe }}&location={{ job.location.city }}, {{ job.location.state_prov_short }}, {{ job.location.country }}{% endcapture %}
                            {% capture similar_jobs_url %}{{ root_url }}search/jobs/?{{ similar_jobs_query }}&per_page=4&ns_job_id={{ job.id }}&ns_similar_jobs=1{% endcapture %}
                            <script>
                                // Ajax load similar jobs
                                ajaxloadjobs('{{ similar_jobs_url }}',function() {
                                    loadjob();
                                });

                                // Job Details page: Previous and Next Opportunity buttons
                                $('.job-details__similar-jobs-item').each(function() {
                                    if ($(this).hasClass('{{ job.external_id }}')) {
                                        $(this).addClass('hide');

                                        var prev_link = $(this).prev().find('a').attr('href');
                                        var next_link = $(this).next().find('a').attr('href');

                                        if (typeof prev_link != 'undefined') {
                                            $('a#job-details__prev-link').attr('href',prev_link).removeClass('hide');
                                        }
                                        if (typeof next_link != 'undefined') {
                                            $('a#job-details__next-link').attr('href',next_link).removeClass('hide');
                                        }
                                    }
                                });
                            </script>
                        </div><!--close .job-details__similar-jobs-->
                    </aside>
                </div><!--close .job-details__sidebar-->
            </div>
        </div>
    </div><!--close .job-details-inner-js-->

</div><!--close #job-details-->
      
{% page_required_footer %}